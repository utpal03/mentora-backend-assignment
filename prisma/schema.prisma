// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           Int      @id @default(autoincrement())
  email        String   @unique
  passwordHash String   @map("password_hash")
  name         String?
  role         Role
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  asParentRelations  ParentStudent[] @relation("ParentUser")
  asStudentRelations ParentStudent[] @relation("StudentUser")
  mentorLessons      Lesson[]        @relation("MentorLessons")
  bookingsAsStudent  Booking[]       @relation("BookingStudent")

  @@map("users")
}

model ParentStudent {
  id             Int      @id @default(autoincrement())
  parentUserId   Int      @map("parent_user_id")
  studentUserId  Int      @map("student_user_id")
  createdAt      DateTime @default(now()) @map("created_at")

  parentUser  User @relation("ParentUser", fields: [parentUserId], references: [id], onDelete: Cascade)
  studentUser User @relation("StudentUser", fields: [studentUserId], references: [id], onDelete: Cascade)

  @@unique([parentUserId, studentUserId])
  @@map("parent_students")
}

model Lesson {
  id          Int      @id @default(autoincrement())
  mentorId    Int      @map("mentor_id")
  title       String
  description String
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  mentor   User      @relation("MentorLessons", fields: [mentorId], references: [id], onDelete: Cascade)
  bookings Booking[]
  sessions Session[]

  @@map("lessons")
}

model Booking {
  id            Int      @id @default(autoincrement())
  studentUserId Int      @map("student_user_id")
  lessonId      Int      @map("lesson_id")
  createdAt     DateTime @default(now()) @map("created_at")

  studentUser User   @relation("BookingStudent", fields: [studentUserId], references: [id], onDelete: Cascade)
  lesson      Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([studentUserId, lessonId])
  @@map("bookings")
}

model Session {
  id        Int      @id @default(autoincrement())
  lessonId  Int      @map("lesson_id")
  date      DateTime
  topic     String
  summary   String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

enum Role {
  PARENT
  MENTOR
  STUDENT
}
